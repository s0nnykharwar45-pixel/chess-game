import pygame
import chess
import random

piece_values = {
    chess.PAWN: 1,
    chess.KNIGHT: 3,
    chess.BISHOP: 3,
    chess.ROOK: 5,
    chess.QUEEN: 9,
    chess.KING: 0
}


pygame.init()

WIDTH, HEIGHT = 480, 480
SQ_SIZE = WIDTH // 8

screen = pygame.display.set_mode((WIDTH, HEIGHT))
pygame.display.set_caption("Chess GUI")

board = chess.Board()

# Colors
WHITE = (240, 217, 181)
BROWN = (181, 136, 99)
GREEN = (100, 200, 100)
BLUE = (100, 100, 255)

selected_square = None

# Draw board
def draw_board():
    for row in range(8):
        for col in range(8):
            color = WHITE if (row + col) % 2 == 0 else BROWN
            pygame.draw.rect(screen, color, (col*SQ_SIZE, row*SQ_SIZE, SQ_SIZE, SQ_SIZE))

# Highlight squares
def highlight_squares():
    if selected_square is not None:
        row = 7 - (selected_square // 8)
        col = selected_square % 8

        # Highlight selected square
        pygame.draw.rect(screen, BLUE, (col*SQ_SIZE, row*SQ_SIZE, SQ_SIZE, SQ_SIZE))

        # Highlight legal moves
        for move in board.legal_moves:
            if move.from_square == selected_square:
                to_sq = move.to_square
                r = 7 - (to_sq // 8)
                c = to_sq % 8
                pygame.draw.rect(screen, GREEN, (c*SQ_SIZE, r*SQ_SIZE, SQ_SIZE, SQ_SIZE))

# Draw pieces using Unicode
def draw_pieces():
    font = pygame.font.SysFont("Segoe UI Symbol", 48)

    for square in chess.SQUARES:
        piece = board.piece_at(square)

        if piece:
            row = 7 - (square // 8)
            col = square % 8

            color = (0, 0, 0) if piece.color == chess.BLACK else (255, 255, 255)
            text = font.render(piece.unicode_symbol(), True, color)

            screen.blit(text, (col*SQ_SIZE + 15, row*SQ_SIZE + 10))

# Convert mouse click to square
def get_square(pos):
    x, y = pos
    col = x // SQ_SIZE
    row = y // SQ_SIZE
    return chess.square(col, 7 - row)

running = True

while running:
    draw_board()
    highlight_squares()
    draw_pieces()
    pygame.display.flip()

    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            running = False

        # 👤 Player move
        if event.type == pygame.MOUSEBUTTONDOWN and board.turn == chess.WHITE:
            square = get_square(pygame.mouse.get_pos())

            if selected_square is None:
                # Select only your piece
                piece = board.piece_at(square)
                if piece and piece.color == chess.WHITE:
                    selected_square = square
            else:
                move = chess.Move(selected_square, square)

                if move in board.legal_moves:
                    board.push(move)
                selected_square = None

    # 🤖 AI move
    if board.turn == chess.BLACK and not board.is_game_over():
        pygame.time.delay(400)
        move = random.choice(list(board.legal_moves))
        board.push(move)
print("checkmate")
pygame.quit()
