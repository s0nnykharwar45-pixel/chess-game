import chess

# ✅ 1. Evaluation
piece_values = {
    chess.PAWN: 1,
    chess.KNIGHT: 3,
    chess.BISHOP: 3,
    chess.ROOK: 5,
    chess.QUEEN: 9,
    chess.KING: 0
}

def evaluate(board):
    score = 0
    for piece_type in piece_values:
        score += len(board.pieces(piece_type, chess.WHITE)) * piece_values[piece_type]
        score -= len(board.pieces(piece_type, chess.BLACK)) * piece_values[piece_type]
    return score


# ✅ 2. Minimax
def minimax(board, depth, is_maximizing):
    if depth == 0 or board.is_game_over():
        return evaluate(board)

    if is_maximizing:
        max_eval = -9999
        for move in board.legal_moves:
            board.push(move)
            eval = minimax(board, depth - 1, False)
            board.pop()
            max_eval = max(max_eval, eval)
        return max_eval
    else:
        min_eval = 9999
        for move in board.legal_moves:
            board.push(move)
            eval = minimax(board, depth - 1, True)
            board.pop()
            min_eval = min(min_eval, eval)
        return min_eval


# ✅ 3. Best move
def best_move(board, depth):
    best_val = -9999
    best_mv = None

    for move in board.legal_moves:
        board.push(move)
        value = minimax(board, depth - 1, False)
        board.pop()

        if value > best_val:
            best_val = value
            best_mv = move

    return best_mv


# ✅ 4. CREATE BOARD (THIS WAS MISSING ❗)
board = chess.Board()

# ✅ 5. Improved game loop (readable output)
move_number = 1

while not board.is_game_over():
    print(f"\nMove {move_number}")
    print(board.unicode())   # nicer board

    move = best_move(board, 2)
    print("AI plays:", move)

    board.push(move)
    move_number += 1

print("\nFinal Position:")
print(board.unicode())
print("Game Over!")
